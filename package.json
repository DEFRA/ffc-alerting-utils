{
  "name": "ffc-alerting-utils",
  "version": "1.0.15",
  "description": "Helper library for universal alerting functions between ffc-pay and ffc-doc alert services",
  "homepage": "https://github.com/DEFRA/ffc-alerting-utils",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DEFRA/ffc-alerting-utils.git"
  },
  "main": "app/index.js",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:unit": "PORT=0 node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=test/unit",
    "test:watch": "jest --coverage=false --onlyChanged --watch --runInBand",
    "test:lint": "eslint",
    "test:lint:fix": "eslint --fix"
  },
  "author": "Defra",
  "contributors": [
    "Leigh Godson leigh.godson@atos.net",
    "Sam Plackett samuel.plackett@atos.net"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@azure/identity": "4.13.1",
    "ffc-messaging": "2.10.6",
    "ffc-pay-event-publisher": "1.2.5",
    "notifications-node-client": "8.2.1"
  },
  "devDependencies": {
    "eslint": "9.39.2",
    "jest": "29.7.0",
    "jest-junit": "17.0.0",
    "neostandard": "0.12.2",
    "nodemon": "3.0.1"
  },
  "nodemonConfig": {
    "ignore": [
      "**/test-output/**"
    ]
  }
}
